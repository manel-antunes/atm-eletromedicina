# ── Base de dados ────────────────────────────────────────────
# URL de ligação ao PostgreSQL (fornecida pelo Render/Supabase/etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── JWT ──────────────────────────────────────────────────────
# Segredos para assinar os tokens — usar strings longas e aleatórias em produção
JWT_SECRET=muda-isto-em-producao
JWT_REFRESH_SECRET=muda-isto-em-producao-refresh

# ── Email (Gmail SMTP) ───────────────────────────────────────
# Conta Gmail usada para enviar alertas e notificações
GMAIL_USER=exemplo@gmail.com
# App Password do Gmail (não a password normal) — gerar em myaccount.google.com/apppasswords
GMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# ── Push Notifications (VAPID) ───────────────────────────────
# Gerar com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── CORS ─────────────────────────────────────────────────────
# URL do frontend em produção (ex: https://atm-eletromedicina.vercel.app)
FRONTEND_URL=https://atm-eletromedicina.vercel.app

# ── Ambiente ─────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
